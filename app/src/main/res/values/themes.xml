<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HermesAgent" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.HermesAgent.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_hermes_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.HermesAgent</item>
    </style>
</resources>
